      <material name="">
        <color rgba="0.29412 0.29412 0.29412 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://moveo_description/meshes/Link_4_col.stl"/>
      </geometry>
    </collision>
  </link>
  <joint name="Joint_4" type="revolute">
    <origin xyz="0.16988000 -0.00099213 0.00000000" rpy="-0.04402676 1.00297628 -1.60635499"/>
    <parent link="Link_3"/>
    <child link="Link_4"/>
    <axis xyz="0.010353 -0.99993 -0.0059382"/>
    <limit lower="-1.5707" upper="1.5707" effort="5" velocity="1"/>
  </joint>

  <link name="Link_5">
    <inertial>
      <origin xyz="-0.01136600 0.00012239 0.00789670" rpy="0 0 0"/>
      <mass value="0.19875"/>
      <inertia ixx="6.2676e-05" ixy="4.2551e-06" ixz="4.0215e-05"
               iyy="9.7792e-05" iyz="8.5888e-07" izz="9.5807e-05"/>
