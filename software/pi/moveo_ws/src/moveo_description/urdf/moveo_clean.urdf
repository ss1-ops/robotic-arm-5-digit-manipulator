  </link>
  <joint name="Joint_3" type="revolute">
    <origin xyz="0.00000000 0.00000000 -0.22112000" rpy="0.00000124 1.56835920 0.00000000"/>
    <parent link="Link_2"/>
    <child link="Link_3"/>
    <axis xyz="0 -1 0"/>
    <limit lower="-1.5707" upper="1.5707" effort="5" velocity="1"/>
  </joint>

  <link name="Link_4">
    <inertial>
      <origin xyz="-0.00274170 0.00250970 0.01286400" rpy="0 0 0"/>
      <mass value="0.62964"/>
      <inertia ixx="0.0001717" ixy="1.3446e-06" ixz="8.5164e-06"
               iyy="0.00010506" iyz="5.1412e-05" izz="7.8944e-05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://moveo_description/meshes/Link_4.stl"/>
